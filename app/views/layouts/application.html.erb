<!DOCTYPE html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="Lumen Space - A local-first tool for deep research and structured thinking">
    <title><%= content_for?(:title) ? "#{yield :title} | Lumen Space" : 'Lumen Space' %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag 'application', media: 'all' %>
    <%= javascript_importmap_tags %>
  </head>
  <body>
    <% if notice.present? %>
      <div class="flash flash--notice" data-controller="flash">
        <%= notice %>
        <button class="flash__close" data-action="click->flash#dismiss">×</button>
      </div>
    <% end %>
    <% if alert.present? %>
      <div class="flash flash--alert" data-controller="flash">
        <%= alert %>
        <button class="flash__close" data-action="click->flash#dismiss">×</button>
      </div>
    <% end %>
    <%= yield %>
  </body>
</html>
